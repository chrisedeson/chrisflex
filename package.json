{
  "name": "chrisflex",
  "version": "0.1.0",
  "description": "Lean AI coding workflow manager with persistent memory. Solves context compaction, 200-line doc limits, and token waste.",
  "type": "module",
  "bin": {
    "chrisflex": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "hooks",
    "workflows",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "workflow",
    "memory",
    "claude",
    "copilot",
    "gemini",
    "codex",
    "opencode",
    "coding-assistant",
    "context-management",
    "developer-tools"
  ],
  "author": "Christopher Edeson <edesonchristopher@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisedeson/chrisflex.git"
  },
  "homepage": "https://github.com/chrisedeson/chrisflex#readme",
  "bugs": {
    "url": "https://github.com/chrisedeson/chrisflex/issues"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "picocolors": "^1.1.1",
    "simple-git": "^3.32.2",
    "tinyexec": "^1.0.2",
    "tinyglobby": "^0.2.15",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
